#!/usr/bin/env bun
// Thin wrapper: load the CLI and run it. Kept tiny so package.json's `bin`
// points at a stable shebang script while the real logic lives in src/cli.ts.

import { main } from '../src/cli.ts';

main(process.argv.slice(2)).then(
  (code: number) => process.exit(code),
  (err: unknown) => {
    console.error(err);
    process.exit(1);
  },
);
