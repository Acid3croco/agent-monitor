{
  "name": "agent-monitor",
  "version": "0.0.0",
  "description": "TUI dashboard for monitoring Claude Code and Codex sessions",
  "type": "module",
  "private": true,
  "bin": {
    "agent-monitor": "./bin/agent-monitor"
  },
  "scripts": {
    "tui": "bun run src/cli.ts tui",
    "doctor": "bun run src/cli.ts doctor",
    "install-hooks": "bun run src/cli.ts install-hooks",
    "spike:seed": "bun run spike/seed.ts",
    "spike:tui": "bun run spike/tui.tsx",
    "spike:updater": "bun run spike/updater.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "typescript": "^5.7.0"
  }
}
